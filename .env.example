# Supabase — vind deze in je Supabase project: Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Basis-URL van de app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Web push (meldingen) ---
# Genereer met:  npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:arne@halcoservices.be

# Service-role key (Supabase > Settings > API > service_role). SERVER-ONLY, nooit publiek!
SUPABASE_SERVICE_ROLE_KEY=

# Geheime sleutel om de cron-endpoint te beschermen (verzin zelf iets lang & willekeurig)
CRON_SECRET=

# --- Gezondheidsbot (Claude) ---
# API-sleutel van console.anthropic.com (Settings > API Keys)
ANTHROPIC_API_KEY=
# Optioneel: model overschrijven
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MODEL_FAST=claude-haiku-4-5-20251001
